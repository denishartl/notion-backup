# ABOUTME: Example environment variables for notion-backup.
# ABOUTME: Copy to .env and fill in required values before starting the container.

NOTION_TOKEN_PERSONAL=   # REQUIRED — set in Portainer env vars; Notion internal integration token for the `personal` workspace (create at https://www.notion.so/my-integrations).

TZ=Europe/Berlin         # optional; container timezone (affects the backup schedule's cron interpretation).

# Additional workspaces need their own token_env variable, e.g. NOTION_TOKEN_WORK=<token>
